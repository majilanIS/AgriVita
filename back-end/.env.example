# Agrivita Backend Environment Variables
# Copy this file to .env and fill in your actual values

# ==================== Database Configuration ====================
DATABASE_URL=postgresql://username:password@localhost:5432/agrivita_db

# ==================== Security ====================
# Generate a strong secret key for production:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-change-in-production

# ==================== API Keys ====================
# Get these from Kindwise (https://www.kindwise.com)
INSECT_ID=your-kindwise-insect-api-key
CROP_HEALTH=your-kindwise-crop-api-key

# ==================== AI Integration ====================
# Get your Groq API key from https://console.groq.com
GROQ_API_KEY=your-groq-api-key

# ==================== API Base URLs ====================
# These have defaults but can be overridden if needed
INSECT_API_URL=https://insect.kindwise.com/api/v1
CROP_HEALTH_API_URL=https://crop.kindwise.com/api/v1

# ==================== Server Configuration ====================
# Set to false in production
DEBUG=true

# ==================== CORS Configuration ====================
# For development, use *. For production, specify exact domains.
# CORS_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ORIGINS=*
